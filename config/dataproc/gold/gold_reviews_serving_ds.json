{
  "output_name": "reviews_serving_ds",
  "inputs": {
    "reviews": {
      "dataset_name": "books_rating",
      "asset_name": "silver_quality_enriched",
      "format": "parquet"
    }
  },
  "serving": {
    "base_input": "reviews",
    "joins": [],
    "filters": [],
    "select_columns": [
      "book_source_id",
      "title_key",
      "title",
      "review_score",
      "review_timestamp",
      "review_date",
      "review_summary",
      "review_text",
      "title_hash"
    ]
  },
  "output": {
    "dataset_name": "books_rating",
    "asset_name": "gold_reviews_serving_ds",
    "format": "parquet",
    "mode": "overwrite",
    "partitions": 1
  },
  "spark": {
    "app_name": "gold-reviews-serving-ds-prod",
    "driver_memory": "4g",
    "shuffle_partitions": 8,
    "default_parallelism": 4,
    "max_partition_bytes": "134217728",
    "compression": "snappy"
  }
}