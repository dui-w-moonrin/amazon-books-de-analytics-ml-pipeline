{
  "job_name": "books_rating_bronze",
  "source_dataset": "books_rating",
  "source_asset": "raw_csv",
  "output_dataset": "books_rating",
  "output_asset": "bronze_full",
  "source_type": "csv",
  "output_type": "parquet",
  "output_write_mode": "overwrite",
  "write_partitions": 2,
  "max_records_per_file": 50000,
  "csv_options": {
    "header": true,
    "all_varchar": true
  },
  "columns": [
    { "source": "Id", "target": "id" },
    { "source": "Title", "target": "title" },
    { "source": "Price", "target": "price_raw" },
    { "source": "User_id", "target": "user_id" },
    { "source": "profileName", "target": "profile_name" },
    { "source": "review/helpfulness", "target": "review_helpfulness" },
    { "source": "review/score", "target": "review_score_raw" },
    { "source": "review/time", "target": "review_time_raw" },
    { "source": "review/summary", "target": "review_summary" },
    { "source": "review/text", "target": "review_text" }
  ],
  "spark": {
    "master": "local[1]",
    "app_name": "bronze-books-rating",
    "driver_memory": "6g",
    "shuffle_partitions": 2,
    "default_parallelism": 1,
    "max_partition_bytes": "4m",
    "parquet_block_size": "16777216",
    "parquet_page_size": "1048576",
    "compression": "snappy"
  }
}