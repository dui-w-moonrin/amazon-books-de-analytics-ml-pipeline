{
  "job_name": "books_data_bronze",
  "source_dataset": "books_data",
  "source_asset": "raw_csv",
  "output_dataset": "books_data",
  "output_asset": "bronze_full",
  "source_type": "csv",
  "output_type": "parquet",
  "output_write_mode": "overwrite",
  "write_partitions": 4,
  "csv_options": {
    "header": true,
    "all_varchar": true,
    "multiLine": true,
    "quote": "\"",
    "escape": "\"",
    "mode": "PERMISSIVE",
    "ignoreLeadingWhiteSpace": true,
    "ignoreTrailingWhiteSpace": true,
    "encoding": "UTF-8"
  },
  "columns": [
    { "source": "Title", "target": "title" },
    { "source": "description", "target": "description" },
    { "source": "authors", "target": "authors" },
    { "source": "image", "target": "image_url" },
    { "source": "previewLink", "target": "preview_link" },
    { "source": "publisher", "target": "publisher" },
    { "source": "publishedDate", "target": "published_date_raw" },
    { "source": "infoLink", "target": "info_link" },
    { "source": "categories", "target": "categories" },
    { "source": "ratingsCount", "target": "ratings_count_raw" }
  ],
  "spark": {
    "master": "local[1]",
    "app_name": "bronze-books-data",
    "driver_memory": "4g",
    "shuffle_partitions": 8,
    "default_parallelism": 2,
    "max_partition_bytes": "16m"
  }
}