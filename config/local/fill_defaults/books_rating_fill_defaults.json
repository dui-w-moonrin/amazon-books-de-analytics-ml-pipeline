{
  "dataset_name": "books_rating",
  "input_asset": "silver_standardized",
  "output_asset": "silver_defaults_filled",
  "output_format": "parquet",
  "output_write_mode": "overwrite",
  "write_partitions": 32,
  "fill_rules": [
    {
      "column": "user_id",
      "value": "anonymous"
    },
    {
      "column": "profile_name",
      "value": "anonymous"
    }
  ],
  "spark": {
    "master": "local[1]",
    "app_name": "silver-fill-defaults-books-rating",
    "driver_memory": "4g",
    "shuffle_partitions": 8,
    "default_parallelism": 2,
    "max_partition_bytes": "16m"
  }
}